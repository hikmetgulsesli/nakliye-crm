# ============================================
# Nakliye CRM Environment Configuration
# ============================================

# Database Configuration
# SQLite database file path (relative to project root)
DATABASE_PATH=./data/nakliye-crm.db

# NextAuth Configuration
# Generate a strong random string (min 32 characters)
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-min-32-characters
NEXTAUTH_URL=http://localhost:3000

# Optional: Session Configuration
# SESSION_MAX_AGE=28800 # 8 hours in seconds

# Optional: Remember Me Duration
# REMEMBER_ME_MAX_AGE=2592000 # 30 days in seconds
